class Solution {
public:
    bool canBeEqual(vector<int>& target, vector<int>& arr) {
        int count[1001] = {0};

        for (int x : target) count[x]++;
        for (int x : arr) count[x]--;

        for (int i = 0; i <= 1000; i++) {
            if (count[i] != 0) return false;
        }

        return true;
    }
};
