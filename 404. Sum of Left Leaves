class Solution {
public:
    int sumOfLeftLeaves(TreeNode* root) {
        if (!root) return 0;

        int sum = 0;

        // если есть левый ребёнок и он лист
        if (root->left && !root->left->left && !root->left->right) {
            sum += root->left->val;
        }

        // идём дальше по дереву
        sum += sumOfLeftLeaves(root->left);
        sum += sumOfLeftLeaves(root->right);

        return sum;
    }
};
